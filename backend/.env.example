# ── NOTAM Analyzer Environment Config ────────────────────────────────────────
# Copy this to .env and fill in values. Never commit .env to git.

# Required: path to your waypoint CSV dataset
WAYPOINT_CSV=../data/wavepoints.csv

# Security: generate a strong random key (run: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_HEX_STRING

# Allowed origins for CORS (comma-separated). For local use: http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000

# Rate limit: max requests per minute per IP
RATE_LIMIT_PER_MINUTE=30

# Debug mode — set to false in production
FLASK_DEBUG=false
